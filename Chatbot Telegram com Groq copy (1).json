    {
      "parameters": {
        "chatId": "={{ $json.chat_id }}",
        "text": "=Comandos disponíveis:\n/start - Iniciar o bot \n/help - Ver esta mensagem de ajuda \n/sobre - Ver informações sobre o projeto  \nVocê também pode me enviar qualquer pergunta, e eu responderei usando inteligência artificial.",
        "additionalFields": {}
