        "jsonBody": "={\n  \"model\": \"llama-3.1-8b-instant\",\n  \"temperature\": 0.5,\n  \"max_tokens\": 500,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"Você é um chatbot educado, claro e objetivo. Responda sempre em português. Explique os assuntos de forma simples e direta. Se não souber uma resposta, diga que não sabe em vez de inventar informações.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"{{ $json.texto_usuario }}\"\n    }\n  ]\n}",
        "options": {}
