        512,
        -384
      ],
      "id": "f96cff2f-1ab8-497d-a6fa-b2fafe011dc1",
      "name": "Responder /help",
      "webhookId": "21d536b9-e4aa-4c5e-88e2-3eec575cf944",
      "credentials": {
        "telegramApi": {
          "id": "pw2N3DKBweAZwTNu",
          "name": "Telegram account"
        }
      }
    },
    {
      "parameters": {
        "chatId": "={{ $json.chat_id }}",
        "text": "=Este chatbot foi desenvolvido como atividade prática utilizando Telegram, n8n e uma API de Inteligência Artificial.\n\nO fluxo funciona assim:\n\n1. O usuário envia uma mensagem no Telegram.\n2. O n8n recebe essa mensagem pelo Telegram Trigger.\n3. O nó Edit Fields organiza as informações recebidas, como o texto da mensagem, o chat ID e o comando enviado.\n4. O nó Switch verifica se a mensagem é um comando, como /start, /help ou /sobre.\n5. Se for um comando, o bot envia uma resposta pronta.\n6. Se for uma pergunta comum, a mensagem é enviada para a API de Inteligência Artificial.\n7. A resposta gerada pela IA é enviada automaticamente de volta ao usuário no Telegram.\n\nO objetivo do projeto é demonstrar, na prática, a integração entre sistemas, o uso de APIs e a automação de fluxos com o n8n.",
        "additionalFields": {}
      },
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [
        512,
        -240
      ],
      "id": "b06a2385-fecf-4f52-b02c-e18fa08d559f",
      "name": "Responder /sobre",
      "webhookId": "1411b02a-6519-4fbf-9bf1-c897cb242898",
      "credentials": {
        "telegramApi": {
          "id": "pw2N3DKBweAZwTNu",
          "name": "Telegram account"
        }
      }
    },
